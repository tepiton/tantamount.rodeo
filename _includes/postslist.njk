<ol reversed class="postlist" style="--postlist-index: {{ postslistCounter or postslist.length }}">
{%- for post in postslist | reverse %}
	<li class="postlist-item{% if post.url == url %} postlist-item-active{% endif %}">
		<div class="postlist-content">
			<h3 class="postlist-title">
				<a href="{{ post.url }}" class="postlist-link">
					{% if post.data.title %}{{ post.data.title }}{% else %}<code>{{ post.url }}</code>{% endif %}
				</a>
			</h3>
			<!-- <time class="postlist-date" datetime="{{ post.date | htmlDateString }}">{{ post.date | readableDate }}</time> -->
			{% if post.data.excerpt or post.data.description %}
				<p class="postlist-description">{{ post.data.excerpt or post.data.description }}</p>
			{% endif %}
		</div>
	</li>
{%- endfor %}
</ol>
